# Copia este archivo a .env y ajusta los valores.
#
# === BASE DE DATOS (PostgreSQL / Neon) ===
# En Vercel, la integración de Neon inyecta DATABASE_URL y DATABASE_URL_UNPOOLED
# automáticamente: NO hace falta ponerlas a mano allí.
#
# Para desarrollo local necesitas un Postgres (lo más fácil: la cadena de tu
# base de datos Neon, o una rama de desarrollo de Neon). Pega aquí ambas:
DATABASE_URL="postgresql://usuario:clave@host/db?sslmode=require"
# Conexión directa (sin pool) para migraciones / db push. Si tu proveedor no da
# una distinta, repite el mismo valor que DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://usuario:clave@host/db?sslmode=require"

# === SESIÓN (NextAuth) ===
# Genera un secreto propio con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# En local: http://localhost:3000 . En Vercel: la URL del proyecto (https://...).
NEXTAUTH_URL="http://localhost:3000"
